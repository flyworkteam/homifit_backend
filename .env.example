# Environment
NODE_ENV=development
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=homifit
DB_PASSWORD=changeme
DB_NAME=homifit
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=10000

# CORS — comma separated list of allowed origins (required in production)
ALLOWED_ORIGINS=

# Auth
# AUTH_MODE: jwt | dev | auto
#   jwt  — Bearer JWT only (REQUIRED in production)
#   dev  — trust the `x-user-id` header (local only)
#   auto — prefer JWT, fall back to `x-user-id` when no Bearer token is sent
# The values below are LOCAL DEV DEFAULTS. In production you MUST set:
#   NODE_ENV=production  AUTH_MODE=jwt  DEV_AUTH_ENABLED=false
# Startup validation (src/config/env.js) refuses to boot a prod process with
# AUTH_MODE=auto/dev or DEV_AUTH_ENABLED=true, and the auth middleware
# additionally hard-ignores the `x-user-id` header whenever NODE_ENV=production
# regardless of AUTH_MODE — so the dev header can never impersonate users in prod.
AUTH_MODE=auto
DEV_AUTH_ENABLED=true
JWT_SECRET=replace-with-strong-secret
JWT_ISSUER=
JWT_AUDIENCE=

# Firebase Admin (verify Google/Apple sign-in tokens)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# Premium / RevenueCat
PREMIUM_ADMIN_SECRET=
REVENUECAT_WEBHOOK_SECRET=

# OneSignal — push notification provider (used by /api/notifications/push)
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# BunnyCDN — Storage zone for exercise/workout videos
# Pull URL the client streams from. Files served at https://${BUNNY_PULL_HOSTNAME}/<path>
BUNNY_PULL_HOSTNAME=homifit.b-cdn.net
# Storage zone name (used as FTP/Storage username)
BUNNY_STORAGE_ZONE=homifit
# Storage zone access key (acts as both FTP password and HTTP storage API key)
BUNNY_STORAGE_PASSWORD=
# Optional regional storage endpoint (default: storage.bunnycdn.com).
# Use ny / la / sg / syd / br / jh prefixes if your zone is regional.
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
